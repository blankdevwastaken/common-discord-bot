# ── Required ──────────────────────────────────────────────────────────────────
# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Classic prefix for any legacy prefix commands you add (default: !)
PREFIX=!

# Your development server ID — enables INSTANT slash-command updates.
# Remove or leave empty for global deployment (takes up to 1 hour to propagate).
TEST_GUILD_ID=

# Role ID that grants bot-admin privileges (for /reload, /sync, /announce, etc.)
BOT_ADMIN_ROLE_ID=